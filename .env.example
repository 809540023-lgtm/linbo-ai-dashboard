# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # 後端 API 用，千萬不要外洩

# --- Mux 直播 ---
NEXT_PUBLIC_MUX_PLAYBACK_ID=
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# --- Anthropic Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Twilio SMS（可選；不用時用 Supabase Email Magic Link 即可）---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# --- Cron Job 防呆 ---
CRON_SECRET=請設一個隨機長字串

# --- Resend Email（報名確認信 + 活動提醒信）---
# 沒設時 email 函式 graceful no-op（不會 throw），但也不會寄信
# 在 https://resend.com 申請帳號 → API Keys → 建立後貼上
RESEND_API_KEY=
# 寄件人（必須是 resend 已驗證的網域）
# 預設 onboarding@resend.dev 只能寄給帳號擁有者本人，production 請改成自己驗證過的網域
RESEND_FROM=林博活動 <onboarding@resend.dev>

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
